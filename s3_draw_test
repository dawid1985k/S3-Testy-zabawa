procedure S3_RectFill(x,y,w,h:word; color:byte);
 var cmd:word;
begin
 OutW(S3_FRGD_MIX,$0027);
 OutW(S3_FRGD_COLOR,color);
 OutW(S3_PIX_CNTL,$A000);
 OutW(S3_CUR_X,x);
 OutW(S3_CUR_Y,y);
 OutW(S3_MIN_AXIS,h-1);
 OutW(S3_MAJ_AXIS,w-1);
 OutW(S3_CMD,$40B1);
end;
{Rysowanie linie - niedziala}
procedure S3_Line(x1,y1,x2,y2:word; color:word);
var
   dx,dy,adx,ady,maxv,minv,yIsMajor,xPosDir,yPosDir,dir_flag,errTerm,stepAxiel,stepDiag:integer;
   cmd:Word;
 begin
 {Roznica wpsolrzednych}
 dx:= x2-x1;
 dy:= y2-y1;
 adx:=Abs(dx);
 ady:=Abs(dy);
 {MIN / MAX zgodnie z wymogiami S3}
 if adx >ady then
  begin
   maxv:=adx;
   minv:=ady;
  end
  else
  begin
   maxv:=ady;
   minv:=adx;
  end;
 if dx >=0 then
  errTerm := 2*minv-maxv
 else
  errTerm := 2*minv-maxv-1;

 OutW(S3_FRGD_MIX,$0027);
 OutW(S3_FRGD_COLOR,color);
 OutW(S3_PIX_CNTL,$A000);
 OutW(S3_CUR_X,x1);
 OutW(S3_CUR_Y,y1);
 OutW(S3_MAJ_AXIS,maxv-1);
 OutW(S3_DEST_Y,2*(minv-maxv));
 OutW(S3_DEST_X,2*minv);
 OutW(S3_ERR_TERM,errTerm);
 OutW($96E8,maxv-1);
 dir_flag:=0;
 if dy>=0 then dir_flag:=dir_flag or $80;
 if ady > adx then dir_flag:=dir_flag or $40;
 if dx >=0 then dir_flag:=dir_flag or $20;
 cmd:=$2011 or dir_flag;
 OutW(S3_CMD,cmd);
 end;
procedure LoadBMP(const FileName:string; var IMg:TBmp128x64; var Pal:TPalette);
 var
  f:File;
  Header: array[0..53] of Byte;
  Palette: array[0..1023] of Byte;
  Row: array[0..127] of Byte;
  y:integer;
 begin
  Assign(f,FileName);
  Reset(f,1);
  BlockRead(f,Header,54);
  BlockRead(f,Palette,1024);
  for i:= 0 to 255 do
   begin
    Pal[i].B := Palette[i*4+0];
    Pal[i].G := Palette[i*4+1];
    Pal[i].R := Palette[i*4+2];
   end;
  for y:=63 downto 0 do
   begin
    BlockRead(f, Row,128);
    Move(Row, IMg[y][0],128);
   end;
 Close(f);
 end;
procedure SetVGAPalette(var Pal:TPalette);
var
 i:Integer;
 begin
  Port[$3C8]:=0;
  for i:=0 to 255 do
   begin
    Port[$3C9]:=Pal[i].R shr 2;
    Port[$3C9]:=Pal[i].G shr 2;
    Port[$3C9]:=Pal[i].B shr 2;
   end;
 end;
procedure S3_LoadBmp128x64(x,y:word;var IMg: TBMP128x64);
var
 row,col:integer;
 p: ^Byte;
 Xpos,Ypos : word;
 d:Longint;
 begin
  OutW($BAE8,$0047);
  OutW($BEE8,$A000);
  OutW($82E8,y);
  OutW($86E8,x);
  OutW($BEE8,63);
  OutW($96E8,127);
  OutW($9AE8,$51B1);
  for row:=0 to 63 do
   begin
    P:=@Img[row][0];
    for col:=0 to 127 do
     begin
      Port[$E2E8]:=P^;
      Inc(P);
     end;
   end;
 end;
procedure S3_BitVramCopy(SrcX,SrcY,DstX,DstY,Width,Height:Word);
 var Cmd:Word;
     StartSrcX,StartSrcY:Word;
     StartDstX,StartDstY:Word;
     XPositive,YPositive:Boolean;
 begin
  OutW(S3_PIX_CNTL,$A000);
  OutW(S3_FRGD_MIX,$0067);
  XPositive := DstX >= SrcX;
  YPositive := DstY >= SrcY;
  if XPositive then
   begin
    StartSrcX := SrcX;
    StartDstX := DstX;
   end
   else
    begin
     StartSrcX := SrcX + Width -1;
     StartDstX := DstX + Width -1;
    end;
  if YPositive then
   begin
    StartSrcY := SrcY;
    StartDstY := Dsty;
   end
   else
   begin
    StartSrcY:=SrcY + Height - 1;
    StartDstY:=DstY + Height - 1;
   end;
 OutW(S3_CUR_X,StartSrcX);
 OutW(S3_CUR_Y,StartSrcY);
 OutW(S3_DEST_X,StartDstY);
 OutW(S3_DEST_Y,StartDstX);
 {Wymiary obszaru}
 OutW(S3_MIN_AXIS,Height -1);
 OutW(S3_MAJ_AXIS,Width -1);
 {CMD Make}
 Cmd:=$C0C1;
 if XPositive then Cmd:=Cmd or $0020;
 if YPositive then Cmd:=Cmd or $0080;
 OutW(S3_CMD,cmd);
 end;
